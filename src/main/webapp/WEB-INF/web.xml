<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">
    
    <display-name>DocumentConverter</display-name>
    
    <!-- Page d'accueil -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
    
    <!-- ===== SERVLETS PRINCIPALES ===== -->
    
    <!-- 1. Servlet d'Upload -->
    <servlet>
        <servlet-name>UploadServlet</servlet-name>
        <servlet-class>com.conversion.servlets.UploadServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>UploadServlet</servlet-name>
        <url-pattern>/upload</url-pattern>
    </servlet-mapping>
    
    <!-- 2. Servlet de Conversion -->
    <servlet>
        <servlet-name>ConversionServlet</servlet-name>
        <servlet-class>com.conversion.servlets.ConversionServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>ConversionServlet</servlet-name>
        <url-pattern>/convert</url-pattern>
    </servlet-mapping>
    
    <!-- 3. Servlet de Téléchargement -->
    <servlet>
        <servlet-name>DownloadServlet</servlet-name>
        <servlet-class>com.conversion.servlets.DownloadServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>DownloadServlet</servlet-name>
        <url-pattern>/download</url-pattern>
    </servlet-mapping>
    
    <!-- 4. Servlet d'Aperçu (NÉCESSAIRE pour le bouton Aperçu) -->
    <servlet>
        <servlet-name>PreviewServlet</servlet-name>
        <servlet-class>com.conversion.servlets.PreviewServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>PreviewServlet</servlet-name>
        <url-pattern>/preview</url-pattern>
    </servlet-mapping>
    
    <!-- 5. Servlet de Vérification (NÉCESSAIRE pour vérifier si fichier existe) -->
    <servlet>
        <servlet-name>CheckFileServlet</servlet-name>
        <servlet-class>com.conversion.servlets.CheckFileServlet</servlet-class>
    </servlet>
    
    <servlet-mapping>
        <servlet-name>CheckFileServlet</servlet-name>
        <url-pattern>/checkfile</url-pattern>
    </servlet-mapping>
    
</web-app>